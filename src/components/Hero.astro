---
import siteConfig from "@/data/site-config.json";

const { headline, subheadline, cta, ctaHref, image, imageFallback, imageAlt } =
  siteConfig.hero;
---

{/*
 * Hero: minimal — image + one headline + one subhead + one button.
 * No badges, no chips, no kickers. Hierarchy through type weight and spacing.
 *
 * The image uses <picture> so modern browsers get the smaller WebP.
 * Both files are fetched with priority since this is above the fold.
 */}
<section>
  {/* Full-width image with ONLY headline overlaid */}
  <div class="relative w-full">
    <picture>
      <source srcset={image} type="image/webp" />
      <img
        src={imageFallback}
        alt={imageAlt}
        class="w-full h-auto block"
        loading="eager"
        fetchpriority="high"
      />
    </picture>
    {/* Only the headline on the image */}
    <div class="absolute inset-0 flex flex-col items-center justify-center px-6 bg-black/20">
      <h1
        class="font-serif text-4xl leading-tight tracking-tight text-white text-center sm:text-5xl md:text-6xl drop-shadow-lg"
        set:html={headline}
      />
    </div>
  </div>

  {/* Subheadline + CTA below the image */}
  <div class="container py-8 text-center">
    <p class="text-lg text-muted-foreground max-w-md mx-auto">
      {subheadline}
    </p>
    <a
      href={ctaHref}
      class="mt-6 inline-flex h-12 items-center justify-center rounded-full bg-primary px-8 text-base font-medium text-primary-foreground transition-all duration-150 hover:bg-primary/90 active:scale-[0.98]"
    >
      {cta}
    </a>
  </div>
</section>
