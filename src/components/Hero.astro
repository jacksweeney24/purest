---
import siteConfig from "@/data/site-config.json";

const { cta, ctaHref, image, imageFallback, imageAlt } = siteConfig.hero;
---

{/*
 * Split hero: text left, product image right — LMNT-style layout.
 * Purest's light, airy brand feel instead of LMNT's dark aesthetic.
 */}
<section class="w-full bg-stone-50 overflow-hidden">
  <div class="container">
    <div class="grid md:grid-cols-2 min-h-[480px] md:min-h-[560px] items-center gap-8 py-12 md:py-0">

      {/* Left: headline + description + CTA — order-2 on mobile so image shows first */}
      <div class="space-y-3 py-4 md:py-8 order-2 md:order-1">

        {/* Social proof */}
        <div class="flex items-center gap-2 text-sm">
          <span class="text-amber-400 text-lg">★★★★★</span>
          <span class="text-foreground/60">Loved by athletes, parents & everyday hydrators</span>
        </div>

        <h1 class="font-sans font-black uppercase leading-[0.9] tracking-tight text-5xl md:text-6xl lg:text-7xl">
          <span class="block"><span class="text-foreground/30 font-light text-2xl md:text-3xl tracking-[0.3em]" style="font-style:normal">REAL</span></span>
          <span class="block text-foreground">FRUIT</span>
          <span class="block mt-2"><span class="text-foreground/30 font-light text-2xl md:text-3xl tracking-[0.3em]">REAL</span></span>
          <span class="block text-foreground">SALT</span>
          <span class="block mt-2"><span class="text-foreground/30 font-light text-2xl md:text-3xl tracking-[0.3em]">REAL</span></span>
          <span class="block" style="color: var(--color-primary)">HYDRATION</span>
        </h1>

        {/* Benefit bullets */}
        <ul class="space-y-2 text-sm text-foreground/75">
          <li class="flex items-center gap-2"><span class="text-green-600 font-bold">✓</span> 85+ trace minerals from natural sun-dried sea salt</li>
          <li class="flex items-center gap-2"><span class="text-green-600 font-bold">✓</span> 700+ mg naturally occurring sodium — no synthetic salt</li>
          <li class="flex items-center gap-2"><span class="text-green-600 font-bold">✓</span> 0 added sugar, 0 anti-caking agents, 0 maltodextrin</li>
        </ul>

        <a
          href={ctaHref}
          class="inline-flex h-16 items-center justify-center rounded-full bg-primary px-14 text-lg font-medium text-primary-foreground transition-all duration-150 hover:bg-primary/90 active:scale-[0.98]"
        >
          {cta}
        </a>

        <p class="text-xs text-foreground/40">Free shipping on orders over $50</p>
      </div>

      {/* Right: product image — order-1 on mobile so it shows first */}
      <div class="relative h-[360px] md:h-full md:min-h-[560px] -mx-4 md:mx-0 md:-mr-8 lg:-mr-16 order-1 md:order-2">
        <picture>
          <source srcset={image} type="image/webp" />
          <img
            src={imageFallback}
            alt={imageAlt}
            class="absolute inset-0 w-full h-full object-cover object-center"
            loading="eager"
            fetchpriority="high"
          />
        </picture>
      </div>

    </div>
  </div>
</section>
