---
import testimonials from "@/data/testimonials.json";

// `location` is optional — some reviews didn't include one.
// `title` is a short headline like "Excellent!" that prefaces the review body.
interface Testimonial {
  name: string;
  location?: string;
  title: string;
  text: string;
  rating: number;
}

const items = testimonials as Testimonial[];
---

<section class="container py-20 md:py-28">
  <h2 class="font-serif text-3xl tracking-tight md:text-4xl">
    What people are saying
  </h2>

  {/*
   * 5 reviews land as 3+2 in a 3-column grid on desktop. The two on the
   * bottom row left-align — that asymmetry is intentional editorial pacing
   * (Aesop / NYT do this), not a layout bug. On mobile each review stacks.
   */}
  <div class="mt-12 grid grid-cols-1 gap-y-12 gap-x-8 md:grid-cols-3 md:gap-x-10">
    {
      items.map((t) => (
        <figure class="flex flex-col">
          {/*
           * Filled SVG stars in the brand ink color. Inline (not a React
           * island) so they cost zero JS. `aria-label` describes the rating;
           * the individual stars are decorative.
           */}
          <div class="flex gap-0.5" aria-label={`${t.rating} out of 5 stars`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                aria-hidden="true"
                viewBox="0 0 24 24"
                class:list={[
                  "h-3.5 w-3.5",
                  i < t.rating ? "fill-foreground" : "fill-border",
                ]}
              >
                <path d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.563.563 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
              </svg>
            ))}
          </div>

          <h3 class="mt-4 text-base font-medium tracking-tight">{t.title}</h3>

          <blockquote class="mt-2 text-base leading-relaxed text-foreground/85">
            "{t.text}"
          </blockquote>

          <figcaption class="mt-6 text-sm text-muted-foreground">
            <span class="text-foreground">{t.name}</span>
            {t.location && <> · {t.location}</>}
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>
