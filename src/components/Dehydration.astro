---

<section class="bg-stone-50 py-20 md:py-28">
  <div class="container">
    <div class="grid gap-12 md:grid-cols-2 md:items-center">

      <!-- Text -->
      <div class="space-y-8">
        <div>
          <p class="text-xs uppercase tracking-widest text-muted-foreground">You're not just tired</p>
          <h2 class="mt-4 font-serif text-3xl tracking-tight md:text-5xl">
            You're chronically dehydrated.
          </h2>
          <p class="mt-5 text-base leading-relaxed text-foreground/75">
            Purest is the electrolyte you can <em>feel</em> — because it's made from Mother Nature,
            and she knows the perfect balance of trace minerals your body needs.
          </p>
          <p class="mt-3 text-base leading-relaxed text-foreground/75">
            French gray sea salt carries dozens of trace minerals. Paired with the natural
            glucose from real freeze-dried fruit, your cells actually absorb it.
            No confusion. Just relief.
          </p>
        </div>

        <!-- Symptom icons -->
        <div>
          <p class="text-xs uppercase tracking-widest text-muted-foreground mb-4">Purest works fast for</p>
          <div class="flex flex-wrap gap-6">
            <div class="flex items-center gap-2 text-sm font-medium">
              <span class="text-xl">🤕</span> Headaches
            </div>
            <div class="flex items-center gap-2 text-sm font-medium">
              <span class="text-xl">🧠</span> Brain Fog
            </div>
            <div class="flex items-center gap-2 text-sm font-medium">
              <span class="text-xl">⚡</span> Cramps
            </div>
            <div class="flex items-center gap-2 text-sm font-medium">
              <span class="text-xl">😴</span> Fatigue
            </div>
          </div>
        </div>

        <!-- Clean label points -->
        <div class="grid grid-cols-2 gap-3 text-sm text-foreground/70">
          <div class="flex items-center gap-2"><span>✓</span> Zero added sugar</div>
          <div class="flex items-center gap-2"><span>✓</span> No maltodextrin</div>
          <div class="flex items-center gap-2"><span>✓</span> No hidden ingredients</div>
          <div class="flex items-center gap-2"><span>✓</span> No junk. Ever.</div>
        </div>

        <p class="text-sm font-medium uppercase tracking-widest text-foreground/50">
          Feel the difference. Stay your best.
        </p>
      </div>

      <!-- Image placeholder (swap src when photo is ready) -->
      <div class="aspect-[4/5] overflow-hidden rounded-sm bg-stone-100">
        <img
          src="/images/ginger-lime.jpg"
          alt="Pouring Purest Electrolyte into a glass"
          class="h-full w-full object-contain p-6"
        />
      </div>

    </div>
  </div>
</section>
