---
import Layout from "@/layouts/Layout.astro";
import AddToCart from "@/components/AddToCart.tsx";
import { getProduct, getProducts } from "@/lib/shopify";

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((p) => ({ params: { handle: p.handle } }));
}

const { handle } = Astro.params;
const product = await getProduct(handle!);

if (!product) return Astro.redirect("/products");

const price = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: product.priceRange.minVariantPrice.currencyCode,
}).format(parseFloat(product.priceRange.minVariantPrice.amount));
---

<Layout title={`${product.title} · Purest Electrolyte`} description={product.description}>
  <section class="container py-12 md:py-16">

    <!-- Back link -->
    <a href="/products" class="text-sm text-muted-foreground hover:text-foreground mb-8 inline-block">
      ← All flavors
    </a>

    <div class="grid gap-10 md:grid-cols-2 md:items-start">

      <!-- Image gallery -->
      <div class="space-y-3">
        {product.images.length > 0 ? (
          <>
            <!-- Main image -->
            <div class="aspect-square overflow-hidden rounded-lg bg-white">
              <img
                id="main-image"
                src={product.images[0].url}
                alt={product.images[0].altText ?? product.title}
                class="w-full h-full object-contain"
              />
            </div>
            <!-- Thumbnail row -->
            {product.images.length > 1 && (
              <div class="flex gap-2 overflow-x-auto pb-1">
                {product.images.map((img, i) => (
                  <button
                    class="flex-shrink-0 w-20 h-20 rounded-md overflow-hidden bg-white border-2 border-transparent hover:border-primary transition-colors thumbnail-btn"
                    data-src={img.url}
                    data-alt={img.altText ?? product.title}
                  >
                    <img
                      src={img.url}
                      alt={img.altText ?? product.title}
                      class="w-full h-full object-contain"
                    />
                  </button>
                ))}
              </div>
            )}
          </>
        ) : (
          <div class="aspect-square rounded-lg bg-stone-100 flex items-center justify-center">
            <span class="text-muted-foreground text-sm">No image</span>
          </div>
        )}
      </div>

      <!-- Product info -->
      <div class="space-y-6">
        <div>
          <h1 class="font-serif text-3xl tracking-tight md:text-4xl">{product.title}</h1>
          <p class="mt-3 text-2xl font-medium">{price}</p>
        </div>

        {product.description && (
          <p class="text-base leading-relaxed text-foreground/75">{product.description}</p>
        )}

        <!-- Add to cart -->
        <AddToCart product={product} client:load />

        <!-- Clean label badges -->
        <div class="grid grid-cols-2 gap-2 text-sm text-foreground/60 pt-2 border-t border-border">
          <div class="flex items-center gap-2"><span>✓</span> Zero added sugar</div>
          <div class="flex items-center gap-2"><span>✓</span> No maltodextrin</div>
          <div class="flex items-center gap-2"><span>✓</span> Real fruit only</div>
          <div class="flex items-center gap-2"><span>✓</span> No junk. Ever.</div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
  // Thumbnail click handler
  document.querySelectorAll('.thumbnail-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const mainImg = document.getElementById('main-image') as HTMLImageElement;
      if (mainImg) {
        mainImg.src = btn.getAttribute('data-src') || '';
        mainImg.alt = btn.getAttribute('data-alt') || '';
      }
      document.querySelectorAll('.thumbnail-btn').forEach(b => b.classList.remove('border-primary'));
      btn.classList.add('border-primary');
    });
  });
</script>
