---
import Layout from "@/layouts/Layout.astro";
import { getArticle, getBlogArticles } from "@/lib/shopify";

export async function getStaticPaths() {
  const articles = await getBlogArticles("science");
  return articles.map((a) => ({ params: { handle: a.handle } }));
}

const { handle } = Astro.params;
const article = await getArticle("science", handle!);
if (!article) return Astro.redirect("/science");
---

<Layout title={`${article.title} · Purest Electrolyte`}>
  <section class="container py-16 md:py-20 max-w-3xl">
    <a href="/science" class="text-sm text-muted-foreground hover:text-foreground mb-8 inline-block">← The Science</a>
    {article.image && (
      <div class="mb-8 aspect-video overflow-hidden rounded-xl bg-stone-100">
        <img src={article.image.url} alt={article.image.altText ?? article.title} class="h-full w-full object-cover" />
      </div>
    )}
    <p class="text-xs text-muted-foreground">{new Date(article.publishedAt).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
    <h1 class="mt-3 font-serif text-3xl tracking-tight md:text-4xl">{article.title}</h1>
    <div class="mt-8 prose prose-stone max-w-none" set:html={article.contentHtml} />
    <div class="mt-16 border-t border-border pt-8">
      <a href="/science" class="text-sm text-muted-foreground hover:text-foreground">← Back to The Science</a>
    </div>
  </section>
</Layout>
