---
import Layout from "@/layouts/Layout.astro";
import SaleBanner from "@/components/SaleBanner.astro";
import Hero from "@/components/Hero.astro";
import ProductGrid from "@/components/ProductGrid.tsx";
import SubscriptionCTA from "@/components/SubscriptionCTA.astro";
import Testimonials from "@/components/Testimonials.astro";
import { getProducts } from "@/lib/shopify";
import FounderStory from "@/components/FounderStory.astro";
import Dehydration from "@/components/Dehydration.astro";
import Comparison from "@/components/Comparison.astro";
import StatsBar from "@/components/StatsBar.astro";

const products = await getProducts();
// Electrolyte flavors first, water bottle last
const flavors = products.filter(p => !p.title.toLowerCase().includes('water bottle'));
const other = products.filter(p => p.title.toLowerCase().includes('water bottle'));
const orderedProducts = [...flavors, ...other];
---

<Layout>
  <SaleBanner />
  <Hero />

  {/* ALL products right below hero — LMNT style, shop without scrolling */}
  <section class="container py-10 md:py-14">
    <h2 class="font-serif text-2xl tracking-tight mb-8 md:text-3xl">Shop all flavors</h2>
    <ProductGrid products={orderedProducts} client:load />
  </section>

  <StatsBar />

  {/* In Each Jar infographic */}
  <section class="bg-white py-2">
    <div class="container max-w-7xl">
      <img
        src="/images/in-each-jar.jpg"
        alt="In each jar: organic hibiscus, organic lime, coconut water, trace minerals from sea salt"
        class="w-full rounded-sm"
      />
    </div>
  </section>

  <Dehydration />
  <Comparison />
  <FounderStory />
  <SubscriptionCTA />
  <Testimonials />
</Layout>
