---
import Layout from "@/layouts/Layout.astro";
import { getBlogArticles, getArticle } from "@/lib/shopify";

const article = await getArticle("news", "purest-electrolyte-named-cristina-cuomos-favorite-electrolyte-in-the-purist-magazines-august-2025-issue");
---

<Layout title="In The Press · Purest Electrolyte">
  <section class="container py-16 md:py-20 max-w-3xl">
    <a href="/" class="text-sm text-muted-foreground hover:text-foreground mb-8 inline-block">← Home</a>
    {article ? (
      <>
        <p class="text-xs uppercase tracking-widest text-muted-foreground">Press</p>
        <h1 class="mt-4 font-serif text-3xl tracking-tight md:text-4xl">{article.title}</h1>
        <p class="mt-2 text-sm text-muted-foreground">{new Date(article.publishedAt).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
        <div class="mt-8 prose prose-stone max-w-none" set:html={article.contentHtml} />
      </>
    ) : (
      <p>Story coming soon.</p>
    )}
  </section>
</Layout>
