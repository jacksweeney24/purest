# Shopify Storefront API credentials.
# Copy this file to `.env` and fill in real values when you have them.
# These are PUBLIC because Astro exposes any var prefixed with PUBLIC_ to the browser.
# The Storefront API token is safe to expose; it's read-only and rate-limited by Shopify.

PUBLIC_SHOPIFY_STORE_DOMAIN=purest-electrolyte.myshopify.com
PUBLIC_SHOPIFY_STOREFRONT_TOKEN=
